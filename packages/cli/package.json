{
  "name": "@basou/cli",
  "version": "0.32.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "basou command-line tool",
  "author": "Takashi Matsuyama",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "session",
    "audit",
    "provenance",
    "git",
    "claude-code"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git",
    "directory": "packages/cli"
  },
  "homepage": "https://basou.dev",
  "bugs": {
    "url": "https://github.com/basou-dev/basou/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./program": {
      "types": "./dist/program.d.ts",
      "import": "./dist/program.js"
    }
  },
  "bin": {
    "basou": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm run clean && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsup *.tsbuildinfo",
    "prepublishOnly": "pnpm -w run build"
  },
  "dependencies": {
    "@basou/core": "workspace:*",
    "commander": "^14.0.3"
  }
}
