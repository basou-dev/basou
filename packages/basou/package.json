{
  "name": "basou",
  "version": "0.26.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Convenience installer for the @basou/cli command. `npm install -g basou` exposes the same `basou` binary as `npm install -g @basou/cli`.",
  "author": "Takashi Matsuyama",
  "keywords": [
    "ai",
    "agent",
    "cli",
    "session",
    "audit",
    "provenance",
    "git",
    "claude-code",
    "basou"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git",
    "directory": "packages/basou"
  },
  "homepage": "https://basou.dev",
  "bugs": {
    "url": "https://github.com/basou-dev/basou/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "basou": "./bin.mjs"
  },
  "files": [
    "bin.mjs"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "prepublishOnly": "pnpm -w run build"
  },
  "dependencies": {
    "@basou/cli": "workspace:*"
  }
}
