{
  "name": "@basou/core",
  "version": "0.2.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Core primitives for Basou: sessions, events, approvals, git capability",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git",
    "directory": "packages/core"
  },
  "homepage": "https://basou.dev",
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsup *.tsbuildinfo"
  },
  "dependencies": {
    "simple-git": "^3.36.0",
    "ulid": "^3.0.2",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  }
}
