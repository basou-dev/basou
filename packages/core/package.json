{
  "name": "@basou/core",
  "version": "0.17.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Core primitives for Basou: sessions, events, approvals, git capability",
  "author": "Takashi Matsuyama",
  "keywords": [
    "ai",
    "agent",
    "session",
    "audit",
    "provenance",
    "git",
    "claude-code",
    "json-schema"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git",
    "directory": "packages/core"
  },
  "homepage": "https://basou.dev",
  "bugs": {
    "url": "https://github.com/basou-dev/basou/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "gen:schemas": "pnpm build && node scripts/gen-schemas.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsup *.tsbuildinfo",
    "prepublishOnly": "pnpm -w run build"
  },
  "dependencies": {
    "simple-git": "^3.36.0",
    "ulid": "^3.0.2",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  }
}
