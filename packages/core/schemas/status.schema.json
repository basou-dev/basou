{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basou.dev/schemas/0.1.0/status.schema.json",
  "title": "Basou Status",
  "description": "The `.basou/status.json` workspace status snapshot.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "workspace": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ws_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ws id: `ws_` followed by a 26-character Crockford Base32 ULID."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "basou_version": {
          "type": "string",
          "const": "0.1.0"
        }
      },
      "required": [
        "id",
        "name",
        "basou_version"
      ],
      "additionalProperties": false
    },
    "directories_present": {
      "type": "object",
      "properties": {
        "sessions": {
          "type": "boolean"
        },
        "tasks": {
          "type": "boolean"
        },
        "approvals_pending": {
          "type": "boolean"
        },
        "approvals_resolved": {
          "type": "boolean"
        },
        "logs": {
          "type": "boolean"
        },
        "raw": {
          "type": "boolean"
        },
        "tmp": {
          "type": "boolean"
        }
      },
      "required": [
        "sessions",
        "tasks",
        "approvals_pending",
        "approvals_resolved",
        "logs",
        "raw",
        "tmp"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schema_version",
    "generated_at",
    "workspace",
    "directories_present"
  ],
  "additionalProperties": false
}
