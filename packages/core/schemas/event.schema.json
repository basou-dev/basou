          "type": "string",
          "minLength": 1
        },
        "prev_hash": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "const": "session_started"
        }
      },
      "required": [
        "schema_version",
        "id",
        "session_id",
        "occurred_at",
        "source",
        "type"
      ]
    },
