{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basou.dev/schemas/0.1.0/task-index.schema.json",
  "title": "Basou Task Index",
  "description": "The `.basou/tasks/index.json` task lookup index.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.\\d+\\.\\d+$"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^task_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "description": "Basou task id: `task_` followed by a 26-character Crockford Base32 ULID."
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "in_progress",
              "done",
              "cancelled"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
          }
        },
        "required": [
          "id",
          "status",
          "updated_at"
        ],
        "additionalProperties": false
      }
    },
    "last_rebuilt_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    }
  },
  "required": [
    "schema_version",
    "tasks",
    "last_rebuilt_at"
  ],
  "additionalProperties": false
}
