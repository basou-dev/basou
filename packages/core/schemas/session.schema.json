{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basou.dev/schemas/0.1.0/session.schema.json",
  "title": "Basou Session",
  "description": "A `.basou/sessions/<id>/session.yaml` session record.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "session": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ses_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ses id: `ses_` followed by a 26-character Crockford Base32 ULID."
        },
        "label": {
          "type": "string"
        },
        "task_id": {
          "anyOf": [
            {
              "type": "string",
              "pattern": "^task_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
              "description": "Basou task id: `task_` followed by a 26-character Crockford Base32 ULID."
            },
            {
              "type": "null"
            }
          ]
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^ws_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ws id: `ws_` followed by a 26-character Crockford Base32 ULID."
        },
        "source": {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "enum": [
                "claude-code-adapter",
                "claude-code-import",
                "codex-import",
                "human",
                "import",
                "terminal"
              ]
            },
            "version": {
              "type": "string",
              "const": "0.1.0"
            },
            "external_id": {
              "type": "string"
            },
            "source_size_bytes": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "kind",
            "version"
          ]
        },
        "started_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "status": {
          "type": "string",
          "enum": [
            "initialized",
            "running",
            "waiting_approval",
            "completed",
            "failed",
            "interrupted",
            "imported",
            "archived"
          ]
        },
        "working_directory": {
          "type": "string",
          "minLength": 1
        },
        "invocation": {
          "type": "object",
          "properties": {
            "command": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "default": [],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exit_code": {
              "anyOf": [
                {
                  "type": "integer",
                  "minimum": -9007199254740991,
                  "maximum": 9007199254740991
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "command",
            "exit_code"
          ]
        },
        "related_files": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "events_log": {
          "default": "events.jsonl",
          "type": "string"
        },
        "summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "metrics": {
          "type": "object",
          "properties": {
            "output_tokens": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "input_tokens": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "cached_input_tokens": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "reasoning_output_tokens": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "active_time_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "active_intervals": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "start": {
                    "type": "string",
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                  },
                  "end": {
                    "type": "string",
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                  }
                },
                "required": [
                  "start",
                  "end"
                ]
              }
            },
            "active_gap_cap_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "active_time_method": {
              "type": "string"
            },
            "machine_active_time_ms": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          }
        }
      },
      "required": [
        "id",
        "workspace_id",
        "source",
        "started_at",
        "status",
        "working_directory",
        "invocation"
      ]
    }
  },
  "required": [
    "schema_version",
    "session"
  ]
}
