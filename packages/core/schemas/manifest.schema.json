{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basou.dev/schemas/0.1.0/manifest.schema.json",
  "title": "Basou Manifest",
  "description": "The `.basou/manifest.yaml` workspace manifest.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^0\\.\\d+\\.\\d+$"
    },
    "basou_version": {
      "type": "string",
      "pattern": "^0\\.\\d+\\.\\d+$"
    },
    "workspace": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ws_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ws id: `ws_` followed by a 26-character Crockford Base32 ULID."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "view": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?![~/\\\\])(?![A-Za-z]:)(?!\\s)[^\\0\\\\]*[^\\0\\\\\\s]$"
        }
      },
      "required": [
        "id",
        "name",
        "created_at",
        "updated_at"
      ],
      "additionalProperties": {}
    },
    "project": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "repository_url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": {}
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "enabled"
      ],
      "additionalProperties": {}
    },
    "approval": {
      "type": "object",
      "properties": {
        "required_for": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "default_risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        }
      },
      "required": [
        "default_risk_level"
      ],
      "additionalProperties": {}
    },
    "adapters": {
      "type": "object",
      "properties": {
        "claude-code": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "config_path": {
              "type": "string"
            }
          },
          "required": [
            "enabled"
          ],
          "additionalProperties": {}
        }
      },
      "required": [
        "claude-code"
      ],
      "additionalProperties": {}
    },
    "git": {
      "type": "object",
      "properties": {
        "events_log": {
          "default": "ignore",
          "type": "string",
          "enum": [
            "ignore",
            "commit"
          ]
        }
      },
      "additionalProperties": {}
    },
    "import": {
      "type": "object",
      "properties": {
        "source_roots": {
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?![~/\\\\])(?![A-Za-z]:)(?!\\s)[^\\0\\\\]*[^\\0\\\\\\s]$"
          }
        }
      },
      "additionalProperties": {}
    },
    "repos": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?![~/\\\\])(?![A-Za-z]:)(?!\\s)[^\\0\\\\]*[^\\0\\\\\\s]$"
          },
          "visibility": {
            "type": "string",
            "enum": [
              "public",
              "private",
              "future-public"
            ]
          },
          "language": {
            "type": "string",
            "enum": [
              "en",
              "ja",
              "en+ja"
            ]
          },
          "publishes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "enum": [
                    "web",
                    "npm"
                  ]
                },
                "visibility": {
                  "type": "string",
                  "enum": [
                    "public",
                    "private",
                    "future-public"
                  ]
                },
                "language": {
                  "type": "string",
                  "enum": [
                    "en",
                    "ja",
                    "en+ja"
                  ]
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": {}
            }
          },
          "instructions": {
            "type": "string",
            "enum": [
              "hub",
              "self"
            ]
          }
        },
        "required": [
          "path"
        ],
        "additionalProperties": {}
      }
    }
  },
  "required": [
    "schema_version",
    "basou_version",
    "workspace",
    "project",
    "capabilities",
    "approval",
    "adapters",
    "git"
  ],
  "additionalProperties": {}
}
