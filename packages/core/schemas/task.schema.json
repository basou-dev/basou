{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://basou.dev/schemas/0.1.0/task.schema.json",
  "title": "Basou Task",
  "description": "The YAML front matter of a `.basou/tasks/<id>.md` task document.",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "task": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^task_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou task id: `task_` followed by a 26-character Crockford Base32 ULID."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "planned",
            "in_progress",
            "done",
            "cancelled"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
        },
        "workspace_id": {
          "type": "string",
          "pattern": "^ws_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ws id: `ws_` followed by a 26-character Crockford Base32 ULID."
        },
        "created_in_session": {
          "type": "string",
          "pattern": "^ses_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
          "description": "Basou ses id: `ses_` followed by a 26-character Crockford Base32 ULID."
        },
        "linked_sessions": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^ses_[0-7][0-9A-HJKMNP-TV-Z]{25}$",
            "description": "Basou ses id: `ses_` followed by a 26-character Crockford Base32 ULID."
          }
        }
      },
      "required": [
        "id",
        "title",
        "status",
        "created_at",
        "updated_at",
        "workspace_id",
        "created_in_session"
      ]
    }
  },
  "required": [
    "schema_version",
    "task"
  ]
}
