{
  "name": "@basou/sdk",
  "version": "0.4.0",
  "type": "module",
  "license": "Apache-2.0",
  "description": "Type-only SDK for Basou adapter authors. v0.1: types only, no runtime.",
  "author": "Takashi Matsuyama",
  "keywords": [
    "ai",
    "agent",
    "sdk",
    "adapter",
    "basou"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://basou.dev",
  "bugs": {
    "url": "https://github.com/basou-dev/basou/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsup *.tsbuildinfo",
    "prepublishOnly": "pnpm -w run build"
  }
}
