{
  "name": "basou-workspace",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=8.15.0"
  },
  "packageManager": "pnpm@9.12.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/basou-dev/basou.git"
  },
  "homepage": "https://basou.dev",
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r --parallel run test:watch",
    "clean": "pnpm -r --parallel clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  }
}
